# Copy this file to .env.local and fill in real values.
# .env.local is git-ignored (see .gitignore line 34).
# Never commit secrets.

# ── QuickBooks Online ─────────────────────────────────────
# These four already exist in Vercel for the back-bar project (production).
# Pull them locally with: vercel env pull .env.production.local
#
# QB_CLIENT_ID, QB_CLIENT_SECRET — from Intuit Developer → MFC Dashboard
# QB_REFRESH_TOKEN, QB_REALM_ID — captured by /api/qb-callback when OAuth ran
QB_CLIENT_ID=
QB_CLIENT_SECRET=
QB_REFRESH_TOKEN=
QB_REALM_ID=
